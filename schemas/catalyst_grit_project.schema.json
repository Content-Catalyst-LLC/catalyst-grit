{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sustainablecatalyst.com/schemas/catalyst-grit-project-v1.7.0.json",
  "title": "Catalyst Grit Recovery Project",
  "type": "object",
  "x-catalyst-grit-version": "1.7.0",
  "additionalProperties": false,
  "required": [
    "project_id",
    "title",
    "status",
    "visibility",
    "owner_id",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "project_id": {
      "type": "string",
      "pattern": "^cgp_[0-9a-f]{32}$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "status": {
      "enum": [
        "active",
        "archived",
        "deleted"
      ]
    },
    "visibility": {
      "const": "private"
    },
    "owner_id": {
      "type": "string",
      "minLength": 1
    },
    "retention_days": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "archived_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "deleted_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    }
  }
}
