{
  "module": "Catalyst Grit",
  "slug": "catalyst-grit",
  "version": "1.9.0",
  "schema_version": "1.9.0",
  "engine_version": "1.9.0",
  "release": "Publication, Export, API, and Institutional Integration",
  "canonical_product_model": "recovery-record",
  "methodology_profile": "cg-recovery-conditions@1.9.0",
  "workspace_format": "catalyst-grit-workspace/1.0",
  "storage": "SQLite private workspace with ordered packaged migrations",
  "migrations": [
    "001_core_workspace",
    "002_checkpoints_reviews_audit",
    "003_recovery_plans_actions_reassessment",
    "004_learning_loops_adaptation_patterns",
    "005_team_recovery_facilitated_review",
    "006_evidence_assumptions_handoffs",
    "007_monitoring_trends_resilience_signals",
    "008_publication_api_institutional_governance"
  ],
  "persistent_entities": [
    "projects",
    "recovery_records",
    "record_revisions",
    "actions",
    "action_events",
    "blockers",
    "checkpoints",
    "reassessments",
    "reviews",
    "status_history",
    "audit_events",
    "retrospectives",
    "pattern_reviews",
    "system_changes",
    "system_change_events",
    "team_memberships",
    "facilitated_sessions",
    "session_participants",
    "team_perspectives",
    "facilitated_agreements",
    "facilitated_agreement_events",
    "evidence_items",
    "evidence_events",
    "evidence_links",
    "assumptions",
    "assumption_events",
    "handoff_artifacts",
    "handoff_events",
    "monitoring_snapshots",
    "monitoring_snapshot_events",
    "monitoring_reviews",
    "institutional_policies",
    "access_reviews",
    "api_clients",
    "api_rate_windows",
    "api_audit_events",
    "publication_artifacts",
    "publication_events",
    "methodology_registry",
    "schema_deprecations"
  ],
  "shortcodes": [
    "[catalyst_grit_demo]",
    "[catalyst_grit_workspace]"
  ],
  "repository": "git@github.com:Content-Catalyst-LLC/catalyst-grit.git",
  "privacy_defaults": {
    "records": "private",
    "public_demo_persistence": false,
    "wordpress_workspace": "authenticated per-user metadata"
  },
  "boundaries": [
    "not mental-health advice",
    "not diagnosis",
    "not character scoring",
    "not performance rating",
    "not employee ranking",
    "not automated eligibility",
    "not outcome guarantee"
  ],
  "release_contract": "scripts/release_contract.py",
  "planning_contract": {
    "action_statuses": [
      "planned",
      "in_progress",
      "blocked",
      "completed",
      "paused",
      "deferred",
      "cancelled"
    ],
    "horizons": [
      "24_hours",
      "72_hours",
      "7_days",
      "longer_term"
    ],
    "scope_decisions": [
      "continue",
      "reduce_scope",
      "pause",
      "delegate",
      "escalate"
    ],
    "history": "append-only action events and reassessments"
  },
  "learning_contract": {
    "retrospective_fields": [
      "what_happened",
      "what_was_expected",
      "what_changed",
      "what_helped",
      "what_hindered",
      "what_was_learned",
      "repeat",
      "redesign",
      "uncertainties"
    ],
    "pattern_categories": [
      "recurring_pressure",
      "dependency_failure",
      "support_gap",
      "clarity_failure",
      "scope_workload",
      "recovery_action_helped",
      "action_did_not_help",
      "adaptation_candidate"
    ],
    "pattern_review_decisions": [
      "accept",
      "reject",
      "correct"
    ],
    "system_change_decisions": [
      "proposed",
      "piloting",
      "adopt",
      "revise",
      "defer",
      "retire"
    ],
    "safeguard": "patterns remain explainable, user-reviewable, non-diagnostic, and non-personality-based"
  },
  "team_recovery_contract": {
    "roles": [
      "owner",
      "facilitator",
      "contributor",
      "reviewer",
      "observer"
    ],
    "membership_statuses": [
      "invited",
      "active",
      "removed"
    ],
    "consent_statuses": [
      "pending",
      "granted",
      "withdrawn"
    ],
    "sharing_scopes": [
      "shared",
      "facilitator_only",
      "private"
    ],
    "session_statuses": [
      "planned",
      "in_progress",
      "completed",
      "cancelled"
    ],
    "agreement_statuses": [
      "proposed",
      "accepted",
      "in_progress",
      "completed",
      "blocked",
      "retired"
    ],
    "safeguard": "team summaries describe shared work conditions and agreements; individual scoring, ranking, diagnosis, personality inference, and hidden evaluation are prohibited"
  },
  "evidence_contract": {
    "types": [
      "note",
      "source_link",
      "file_reference",
      "quote",
      "observation",
      "dataset",
      "calculation",
      "analysis",
      "experiment_result",
      "method",
      "reference_document"
    ],
    "strengths": [
      "unknown",
      "weak",
      "moderate",
      "strong"
    ],
    "review_states": [
      "unreviewed",
      "accepted",
      "questioned",
      "rejected"
    ],
    "relations": [
      "supports",
      "challenges",
      "context",
      "derived_from",
      "conflicts_with"
    ],
    "history": "append-only evidence review events and source-preserving links"
  },
  "assumption_contract": {
    "statuses": [
      "active",
      "validated",
      "rejected",
      "retired"
    ],
    "confidence_range": [
      0,
      100
    ],
    "history": "append-only lifecycle events",
    "boundary": "confidence describes support for a recorded statement, not a person or predicted outcome"
  },
  "handoff_contract": {
    "products": [
      "Catalyst Canvas",
      "Catalyst Data",
      "Workbench",
      "Sustainable Catalyst Lab",
      "Decision Studio",
      "Knowledge Library",
      "Research Librarian",
      "Catalyst Grit",
      "External"
    ],
    "directions": [
      "inbound",
      "outbound"
    ],
    "reference_modes": [
      "snapshot",
      "live_reference"
    ],
    "validation_states": [
      "valid",
      "invalid",
      "stale",
      "conflict"
    ],
    "decision_packet": "sustainable-catalyst-decision-handoff/1.0"
  },
  "capabilities": [
    "governed_publication",
    "multi_format_export",
    "linked_data_export",
    "deterministic_publication_bundles",
    "institutional_api",
    "scoped_authentication",
    "rate_limiting",
    "api_audit",
    "versioned_policies",
    "access_reviews",
    "methodology_governance",
    "schema_deprecation",
    "administrative_diagnostics",
    "longitudinal_monitoring",
    "privacy_thresholded_dashboards",
    "signal_governance",
    "traceable_trends"
  ],
  "api_contract": "catalyst-grit-api/1.0",
  "publication_contract": {
    "report_types": [
      "recovery_brief",
      "facilitated_review_brief",
      "action_plan",
      "learning_loop_report",
      "adaptation_proposal",
      "monitoring_summary",
      "decision_studio_handoff"
    ],
    "formats": [
      "json",
      "jsonld",
      "markdown",
      "html",
      "csv",
      "pdf_request",
      "bundle"
    ],
    "redaction_policies": [
      "none",
      "internal",
      "public"
    ],
    "history": "append-only publication lifecycle events",
    "pdf": "rendered through the Sustainable Catalyst publication layer"
  },
  "publication_bundle_format": "catalyst-grit-publication-bundle/1.0",
  "institutional_api_contract": {
    "contract": "catalyst-grit-api/1.0",
    "authentication": "opaque bearer tokens stored only as SHA-256 hashes",
    "authorization": "scopes plus optional project allowlists",
    "rate_limit": "per-client fixed one-minute windows",
    "audit": "append-only request audit events",
    "resources": [
      "records",
      "revisions",
      "actions",
      "checkpoints",
      "reviews",
      "evidence",
      "patterns",
      "monitoring",
      "handoffs",
      "audit",
      "publications"
    ]
  },
  "institutional_governance_contract": {
    "policy_types": [
      "retention",
      "export_redaction",
      "access_review",
      "methodology_governance",
      "schema_deprecation"
    ],
    "access_review_subjects": [
      "member",
      "api_client",
      "publication",
      "project"
    ],
    "methodology_registry": true,
    "schema_deprecation_registry": true,
    "administrative_diagnostics": true
  }
}
